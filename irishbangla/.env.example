# Firebase web app config.
# Create .env.local from this file for local development.
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Comma-separated emails allowed to use the admin console (client-side check after Firebase sign-in).
# Must match Firestore rules for visaTrackers writes.
VITE_ADMIN_ALLOWED_EMAILS=fineanswer2025@gmail.com
